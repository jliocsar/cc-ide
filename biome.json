{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "**",
      "!src/renderer/src/components/ui",
      "!skills-lock.json",
      "!out",
      "!dist",
      "!.vite",
      "!coverage",
      "!tmp",
      "!.cc-ide",
      "!.claude/worktrees",
      "!.agents"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "jsxQuoteStyle": "double",
      "semicolons": "asNeeded",
      "trailingCommas": "all",
      "arrowParentheses": "always"
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "a11y": {
        "recommended": true,
        "noSvgWithoutTitle": "off",
        "noStaticElementInteractions": "warn",
        "useSemanticElements": "warn",
        "useKeyWithClickEvents": "warn",
        "useValidAriaValues": "warn",
        "noLabelWithoutControl": "warn"
      },
      "correctness": {
        "useExhaustiveDependencies": "warn",
        "noUnusedVariables": "error"
      },
      "suspicious": {
        "noArrayIndexKey": "warn",
        "noConsole": {
          "level": "warn",
          "options": { "allow": ["error", "warn", "info"] }
        },
        "noDuplicateJsxProps": "warn"
      },
      "complexity": {
        "noUselessFragments": "warn"
      }
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "plugins": ["./.biome-plugins/no-empty-fallback-in-selector.grit"],
  "overrides": [
    {
      "includes": ["src/renderer/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "paths": {
                  "fs": "Renderer cannot touch fs; use IPC (window.ccIde.invoke).",
                  "node:fs": "Renderer cannot touch fs; use IPC.",
                  "path": "Renderer cannot use node:path; send paths through IPC.",
                  "node:path": "Renderer cannot use node:path; send paths through IPC.",
                  "child_process": "Renderer cannot spawn processes; use IPC.",
                  "node:child_process": "Renderer cannot spawn processes; use IPC.",
                  "electron": "Use window.ccIde.invoke via src/renderer/src/lib/ipc.ts."
                }
              }
            }
          }
        }
      }
    },
    {
      "includes": ["src/main/modules/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "paths": {
                  "electron": "Deep modules must stay pure; keep Electron APIs in src/main/ipc.ts or src/main/index.ts."
                }
              }
            }
          }
        }
      }
    },
    {
      "includes": ["src/preload/**"],
      "linter": {
        "rules": {
          "style": {
            "useImportType": "error"
          }
        }
      }
    }
  ]
}
